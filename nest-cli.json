{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/card-issuer/src",
  "monorepo": true,
  "root": "apps/card-issuer",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/card-issuer/tsconfig.app.json"
  },
  "projects": {
    "card-issuer": {
      "type": "application",
      "root": "apps/card-issuer",
      "entryFile": "main",
      "sourceRoot": "apps/card-issuer/src",
      "compilerOptions": {
        "webpack": true,
        "tsConfigPath": "apps/card-issuer/tsconfig.app.json"
      }
    },
    "card-processor": {
      "type": "application",
      "root": "apps/card-processor",
      "entryFile": "main",
      "sourceRoot": "apps/card-processor/src",
      "compilerOptions": {
        "webpack": true,
        "tsConfigPath": "apps/card-processor/tsconfig.app.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "kafka": {
      "type": "library",
      "root": "libs/kafka",
      "entryFile": "index",
      "sourceRoot": "libs/kafka/src",
      "compilerOptions": {
        "tsConfigPath": "libs/kafka/tsconfig.lib.json"
      }
    },
    "logger": {
      "type": "library",
      "root": "libs/logger",
      "entryFile": "index",
      "sourceRoot": "libs/logger/src",
      "compilerOptions": {
        "tsConfigPath": "libs/logger/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}
