{
  "name": "io-backend-test",
  "version": "0.0.1",
  "description": "Card issuance system - event-driven architecture",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:issuer": "nest build card-issuer",
    "build:processor": "nest build card-processor",
    "start:issuer": "nest start card-issuer",
    "start:processor": "nest start card-processor",
    "start:issuer:dev": "nest start card-issuer --watch",
    "start:processor:dev": "nest start card-processor --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "11.1.23",
    "@nestjs/core": "11.1.23",
    "@nestjs/platform-express": "11.1.23",
    "compression": "1.8.1",
    "helmet": "8.2.0",
    "ioredis": "5.10.1",
    "kafkajs": "2.2.4",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.23",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.4",
    "@types/supertest": "7.2.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.2.6",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "@contracts/(.*)": "<rootDir>/libs/contracts/src/$1",
      "@contracts": "<rootDir>/libs/contracts/src/index",
      "@common/(.*)": "<rootDir>/libs/common/src/$1",
      "@common": "<rootDir>/libs/common/src/index",
      "@kafka/(.*)": "<rootDir>/libs/kafka/src/$1",
      "@kafka": "<rootDir>/libs/kafka/src/index",
      "@logger/(.*)": "<rootDir>/libs/logger/src/$1",
      "@logger": "<rootDir>/libs/logger/src/index"
    }
  }
}
